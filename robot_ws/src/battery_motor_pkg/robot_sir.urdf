<?xml version="1.0"?>
<robot name="sir_mobile_robot" xmlns:xacro="http://ros.org/wiki/xacro">

  <material name="chassis_color"><color rgba="0.8 0.8 0.8 1.0"/></material>
  <material name="wheel_color"><color rgba="0.1 0.1 0.1 1.0"/></material>
  <material name="lidar_color"><color rgba="1.0 0.8 0.0 1.0"/> </material>
  <material name="led_color"><color rgba="0.0 1.0 0.0 1.0"/> </material>
  <material name="bumper_color"><color rgba="0.2 0.2 0.2 1.0"/></material>
  <material name="component_color"><color rgba="0.3 0.3 0.3 1.0"/></material>

  <link name="base_footprint"/>

  <joint name="base_footprint_joint" type="fixed">
    <parent link="base_footprint"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/> </joint>

  <link name="base_link">
    <visual>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.6 0.4 0.15"/></geometry>
      <material name="chassis_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0.05" rpy="0 0 0"/>
      <geometry><box size="0.6 0.4 0.15"/></geometry>
    </collision>
    <inertial>
      <mass value="15.0"/>
      <origin xyz="0 0 0.05"/>
      <inertia ixx="0.2" ixy="0.0" ixz="0.0" iyy="0.45" iyz="0.0" izz="0.6"/>
    </inertial>
  </link>

  <link name="left_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="wheel_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.0075"/>
    </inertial>
  </link>

  <joint name="left_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="left_wheel"/>
    <origin xyz="-0.1 0.225 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="right_wheel">
    <visual>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
      <material name="wheel_color"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="1.5708 0 0"/>
      <geometry><cylinder radius="0.1" length="0.05"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.004" ixy="0" ixz="0" iyy="0.004" iyz="0" izz="0.0075"/>
    </inertial>
  </link>

  <joint name="right_wheel_joint" type="continuous">
    <parent link="base_link"/>
    <child link="right_wheel"/>
    <origin xyz="-0.1 -0.225 0" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
  </joint>

  <link name="caster_wheel">
    <visual>
      <geometry><sphere radius="0.05"/></geometry>
      <material name="wheel_color"/>
    </visual>
    <collision>
      <geometry><sphere radius="0.05"/></geometry>
    </collision>
  </link>
  <joint name="caster_joint" type="fixed">
    <parent link="base_link"/>
    <child link="caster_wheel"/>
    <origin xyz="0.25 0 -0.05" rpy="0 0 0"/>
  </joint>

  <link name="battery_link">
    <visual>
      <geometry><box size="0.2 0.15 0.08"/></geometry>
      <material name="component_color"/>
    </visual>
    <inertial><mass value="5.0"/><inertia ixx="0.01" ixy="0" ixz="0" iyy="0.01" iyz="0" izz="0.01"/></inertial>
  </link>
  <joint name="battery_joint" type="fixed">
    <parent link="base_link"/>
    <child link="battery_link"/>
    <origin xyz="-0.15 0 0.08" rpy="0 0 0"/>
  </joint>

  <link name="motor_kinco_left">
    <visual><geometry><cylinder radius="0.03" length="0.1"/></geometry><material name="component_color"/></visual>
  </link>
  <joint name="motor_kinco_left_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_kinco_left"/>
    <origin xyz="-0.1 0.15 0" rpy="1.5708 0 0"/>
  </joint>

  <link name="motor_kinco_right">
    <visual><geometry><cylinder radius="0.03" length="0.1"/></geometry><material name="component_color"/></visual>
  </link>
  <joint name="motor_kinco_right_joint" type="fixed">
    <parent link="base_link"/>
    <child link="motor_kinco_right"/>
    <origin xyz="-0.1 -0.15 0" rpy="1.5708 0 0"/>
  </joint>

  <link name="sick_nano3_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><cylinder radius="0.05" length="0.08"/></geometry>
      <material name="lidar_color"/>
    </visual>
    <collision>
      <geometry><cylinder radius="0.05" length="0.08"/></geometry>
    </collision>
  </link>
  <joint name="lidar_joint" type="fixed">
    <parent link="base_link"/>
    <child link="sick_nano3_link"/>
    <origin xyz="0.25 0 0.165" rpy="0 0 0"/> </joint>

  <link name="bumper_link">
    <visual>
      <geometry><box size="0.05 0.42 0.05"/></geometry>
      <material name="bumper_color"/>
    </visual>
    <collision>
      <geometry><box size="0.05 0.42 0.05"/></geometry>
    </collision>
  </link>
  <joint name="bumper_joint" type="fixed">
    <parent link="base_link"/>
    <child link="bumper_link"/>
    <origin xyz="0.325 0 0.05" rpy="0 0 0"/>
  </joint>

  <link name="status_led_link">
    <visual>
      <geometry><sphere radius="0.02"/></geometry>
      <material name="led_color"/>
    </visual>
  </link>
  <joint name="status_led_joint" type="fixed">
    <parent link="base_link"/>
    <child link="status_led_link"/>
    <origin xyz="-0.25 0 0.14" rpy="0 0 0"/> </joint>

  <ros2_control name="KincoMD60System" type="system">
    <hardware>
      <plugin>ros2_canopen/CanopenSystemHardware</plugin>
      </hardware>
    <joint name="left_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
    <joint name="right_wheel_joint">
      <command_interface name="velocity"/>
      <state_interface name="position"/>
      <state_interface name="velocity"/>
    </joint>
  </ros2_control>

</robot>